# ── Required ────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# ── Alert mentions (at least one required) ─────────────────
# Set a user ID, a role ID, or both. Bot won't start if neither is set.
ALERT_USER_ID=your_discord_user_id_here
# ALERT_ROLE_ID=your_discord_role_id_here

# ── Optional (defaults shown) ──────────────────────────────
CHANNEL_NAME=server-monitor
SUDO_ROLE_NAME=sudo

# ── Multi-owner (comma-separated Discord user IDs) ─────────
# Users who can run dangerous commands (exec, sudo, reboot, service).
# Defaults to ALERT_USER_ID if not set.
OWNER_IDS=123456789,987654321

# ── Logging ────────────────────────────────────────────────
# LOG_LEVEL=info       # trace, debug, info, warn, error, fatal

# ── Timezone & scheduling ──────────────────────────────────
# TIMEZONE=UTC
# DAILY_CRON=30 18 * * *
# WEEKLY_CRON=30 18 * * 0
# SECURITY_SCAN_CRON=0 12 * * *

# ── Power monitoring ───────────────────────────────────────
# Watts consumed by components RAPL doesn't measure (mobo, fans, RAM, drives)
# POWER_BASE_LOAD_W=33
# PSU_WATTAGE=450

# ── Security thresholds ────────────────────────────────────
# SSH_FAIL_WARN_THRESHOLD=10
# SSH_FAIL_CRIT_THRESHOLD=50
# SECURITY_ALERT_COOLDOWN_MS=1800000
# SECURITY_EVENT_RETENTION_MS=3600000
# SSH_FAIL_WINDOW_MS=900000
# SSH_FAIL_WINDOW_WARN_THRESHOLD=40
# SSH_FAIL_WINDOW_CRIT_THRESHOLD=150
# SSH_FAIL_PER_IP_WARN_THRESHOLD=15
# SSH_FAIL_PER_IP_CRIT_THRESHOLD=60
# UFW_BLOCK_BATCH_WARN_THRESHOLD=250
# UFW_BLOCK_BATCH_CRIT_THRESHOLD=1000
# NGINX_ATTACK_BATCH_WARN_THRESHOLD=25
# NGINX_ATTACK_BATCH_CRIT_THRESHOLD=100

# Remote shell execution is disabled by default for safety.
# Set true only if you understand the risk of Discord-triggered shell access.
# ENABLE_REMOTE_SHELL=false

# ── Expected ports (comma-separated, ports your services use) ─
# Default: 22,53,80,443. Add your custom ports here.
# EXPECTED_PORTS=22,53,80,443,5432,6379,8080

# ── Watched processes (comma-separated) ────────────────────
# WATCHED_PM2_IDS=1,2
# WATCHED_DOCKER_IDS=abc123,def456

# ── PM2 ────────────────────────────────────────────────────
# PM2_USER=your_linux_username

# ── Log paths (auto-detected per distro, override if needed) ─
# AUTH_LOG=/var/log/auth.log
# SYSLOG_PATH=/var/log/syslog
# UFW_LOG=/var/log/ufw.log

# ── Nginx log paths ────────────────────────────────────────
# NGINX_ACCESS_LOG=/var/log/nginx/access.log
# NGINX_ERROR_LOG=/var/log/nginx/error.log
