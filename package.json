{
  "name": "linux-server-monitor-bot",
  "version": "2.0.0",
  "description": "Discord bot for monitoring and protecting Linux servers — real-time stats, security alerts, intrusion detection, and remote management",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check": "eslint . && prettier --check .",
    "test": "jest --verbose",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "discord-bot",
    "server-monitoring",
    "linux",
    "security",
    "intrusion-detection",
    "fail2ban",
    "system-monitor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.4.2",
    "prettier": "^3.3.0"
  }
}
